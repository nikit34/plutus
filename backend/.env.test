NODE_ENV=test
DATABASE_URL=postgres://test:test@localhost:5432/test
JWT_SECRET=test-jwt-secret-for-unit-tests-only-not-a-real-key
DOWNLOAD_SECRET=test-download-secret-for-unit-tests-only
NOWPAYMENTS_IPN_SECRET=test-nowpayments-ipn-secret
BCRYPT_ROUNDS=4

# Empty on purpose — avoid picking up real creds from a sibling .env that a dev
# might have set locally. isProviderConfigured() must be false in unit tests.
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_X_CLIENT_ID=
OAUTH_X_CLIENT_SECRET=
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_EMAIL=
NOWPAYMENTS_PASSWORD=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=

# --- Server ---
NODE_ENV=development
PORT=4000
# Public base URL of this API (used in emails, Stripe return_urls, download links)
API_BASE_URL=http://localhost:4000
# Public base URL of the frontend (used for redirect after Stripe checkout)
FRONTEND_BASE_URL=http://localhost:5173
# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:5173,https://plutus.firstmessage.ru

# --- Database (Postgres) ---
DATABASE_URL=postgres://plutus:plutus@localhost:5432/plutus

# --- Auth ---
# 32+ random bytes; generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_me_with_a_long_random_string
JWT_TTL=30d
BCRYPT_ROUNDS=12
# Secret used to sign download tokens (HMAC). Same as JWT_SECRET is fine.
DOWNLOAD_SECRET=replace_me_with_a_long_random_string
DOWNLOAD_TTL_SECONDS=604800

# --- Stripe (TEST MODE) ---
# Get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
# Signing secret from `stripe listen` or webhook endpoint settings
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Platform fee percent taken from each sale (0.05 = 5%)
PLATFORM_FEE_PCT=0.05

# --- Email (Resend) ---
RESEND_API_KEY=re_xxx
EMAIL_FROM=Plutus <noreply@plutus.firstmessage.ru>

# --- Crypto payments (NOWPayments) ---
# Get API key from https://account.nowpayments.io/store/api-keys
# IPN secret from https://account.nowpayments.io/store/ipn (must match webhook endpoint)
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
# Set to "true" to use https://api-sandbox.nowpayments.io for testing
NOWPAYMENTS_SANDBOX=false
# For outgoing payouts (Mass Payouts API). Owner account email/password — used to mint a 5-min JWT.
# Also: disable mandatory 2FA on payouts in your NOWPayments account settings.
NOWPAYMENTS_EMAIL=
NOWPAYMENTS_PASSWORD=

# --- Storage ---
# Absolute or relative path for user-uploaded files (created automatically)
STORAGE_DIR=./storage
# Max upload size in MB
MAX_UPLOAD_MB=100

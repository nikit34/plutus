# Frontend (Vite) — copy to .env.local for development
# Base URL of the backend API. Leave empty to use the Vite dev proxy (relative /api).
VITE_API_BASE_URL=http://localhost:4000

# Set to /plutus/ when hosting under a subpath (e.g. GitHub Pages).
# Leave unset (or "/") for subdomain root deploys.
# VITE_BASE=/

# Google Analytics Measurement ID (e.g. G-XXXXXXXXXX). Leave empty to disable.
# VITE_GA_ID=

# Yandex.Metrika counter ID (e.g. 12345678). Leave empty to disable.
# VITE_YM_ID=

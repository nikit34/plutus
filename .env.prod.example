# docker-compose.prod.yml reads POSTGRES_PASSWORD from here and wires the rest through
# backend/.env (loaded by the api container via env_file). Two separate files:
#
#   .env           → repo-root, used by docker-compose (POSTGRES_PASSWORD, VITE build args)
#   backend/.env   → used by the Node api at runtime (everything the app needs)
#
# This file is the TEMPLATE for the repo-root .env.

# --- Postgres (compose-level) ---
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Build args passed to the web container ---
# Keep VITE_API_BASE_URL empty to serve the SPA on the same origin as /api and /files.
VITE_API_BASE_URL=
# Google Analytics measurement ID (optional)
VITE_GA_ID=

# ---------------------------------------------------------------
# backend/.env (runtime, what Node actually reads) should also be
# present. Copy backend/.env.example → backend/.env and fill in:
#   NODE_ENV=production
#   PORT=4000
#   API_BASE_URL=https://plutus.firstmessage.ru
#   FRONTEND_BASE_URL=https://plutus.firstmessage.ru
#   CORS_ORIGINS=https://plutus.firstmessage.ru
#   JWT_SECRET=<openssl rand -hex 48>
#   DOWNLOAD_SECRET=<openssl rand -hex 48>
#   STRIPE_SECRET_KEY=sk_live_...
#   STRIPE_WEBHOOK_SECRET=whsec_...
#   RESEND_API_KEY=re_...
#   EMAIL_FROM=Plutus <noreply@plutus.firstmessage.ru>
#   NOWPAYMENTS_API_KEY=...
#   NOWPAYMENTS_IPN_SECRET=...
#   NOWPAYMENTS_EMAIL=...
#   NOWPAYMENTS_PASSWORD=...
#   OAUTH_GOOGLE_CLIENT_ID=...
#   OAUTH_GOOGLE_CLIENT_SECRET=...
#   OAUTH_X_CLIENT_ID=...
#   OAUTH_X_CLIENT_SECRET=...
#
# DATABASE_URL is set automatically by docker-compose — do NOT put it in backend/.env.
# STORAGE_DIR is set automatically to /app/storage — do NOT override.
